# Reference only — the master's backend list is GENERATED into haproxy.cfg from
# fleet.json by `edge deploy` (HAProxy doesn't read env vars). Set the node IPs
# with `edge fleet`, not here.
#
# Node IPs come from fleet.json, e.g.:
#   node1 = 192.168.1.11
#   node2 = 192.168.1.12
#
# Shared model served by every node (fleet.json `model`):
#   LLM_MODEL=llama3.2:3b
