# camera-vision config. Copy to .env (gitignored); docker compose reads it automatically.

# Camera IP the gateway pulls the MJPEG stream from (required — set your camera's IP).
ESP32_HOST=

# Base image for the gateway container. Leave default on an x86 NVIDIA host;
# on the Jetson set the L4T image:
#   BASE_IMAGE=ultralytics/ultralytics:latest-jetson-jetpack6
BASE_IMAGE=ultralytics/ultralytics:latest

# Optional overrides (defaults shown):
# YOLO_MODEL=yolov8m-oiv7.pt
# CONF=0.3
# DETECT_FPS=8
# GATEWAY_PORT=8000
# OLLAMA_HOST=host.docker.internal:11434
# VLM_MODEL=moondream
