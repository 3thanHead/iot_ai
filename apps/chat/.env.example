# chat config. Copy to .env (gitignored).

# The LLM cluster's single endpoint (HAProxy, native Ollama API), used for
# /api/tags (model list) and /api/chat (streaming). When you launch via
# `edge up chat` this is injected from fleet.json (run `edge fleet` to set the
# master IP); override here only for a standalone run.
LLM_BASE_URL=http://host.docker.internal:11434
