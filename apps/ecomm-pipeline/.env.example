# ecomm-pipeline config. Copy to .env (gitignored).

# --- LLM cluster (text) ---
# The cluster's single endpoint (HAProxy, Ollama native API). When you launch via
# `edge up ecomm-pipeline` this is injected from fleet.json (run `edge fleet` to set
# the master IP), so you can leave the default; override here only for a standalone run.
LLM_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=llama3.2:3b

# --- Artwork (Stable Diffusion) ---
# A local Automatic1111-compatible txt2img endpoint, e.g. http://host.docker.internal:7860
# Leave EMPTY to use the built-in placeholder generator (pipeline still runs).
SD_BASE_URL=
SD_STEPS=28

# --- Brand identity (injected into prompts) ---
BRAND_NAME=Driftwell
BRAND_VOICE=playful, minimalist, a little nerdy
BRAND_GUIDELINES=Clean vector-style designs, bold readable typography, limited 2-3 colour palettes, no photorealism, no busy backgrounds.

# --- Pipeline behaviour ---
WIP_LIMIT=3              # max concurrent in-flight jobs
TICK_INTERVAL=15s       # how often the engine advances work
GATE_NICHE=true         # pause for niche approval before product selection

# --- Server ---
ECOMM_PORT=8810         # host port (container always listens on 8810)
