# Root .env — shared firmware secrets only. Copy to .env (gitignored) and fill in.
# These are injected into the ESP32 firmware build at compile time by iotctl.
# Per-app config lives in each app's own .env (e.g. apps/camera-vision/.env).

# 2.4 GHz network the ESP32 joins (WROOM-32E has no 5 GHz radio).
WIFI_SSID=YourNetworkName
WIFI_PASS=YourPassword
