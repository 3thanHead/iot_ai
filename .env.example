# Host-side secrets for iot_ai. Copy to .env (gitignored) and fill in.
# These are injected into the firmware build at compile time by fleetctl.

# 2.4 GHz network the ESP32 joins (WROOM-32E has no 5 GHz radio).
WIFI_SSID=YourNetworkName
WIFI_PASS=YourPassword

# --- gateway (docker compose reads these too) ---
# Camera IP the gateway pulls the MJPEG stream from.
ESP32_HOST=192.168.1.164
# Base image for the gateway container. Leave default on an x86 NVIDIA host;
# on the Jetson set the L4T image:
#   BASE_IMAGE=ultralytics/ultralytics:latest-jetson-jetpack6
BASE_IMAGE=ultralytics/ultralytics:latest
# Optional overrides (defaults shown):
# YOLO_MODEL=yolov8m-oiv7.pt
# CONF=0.3
# DETECT_FPS=8
# OLLAMA_HOST=localhost:11434
# VLM_MODEL=moondream
